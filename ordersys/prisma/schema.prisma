generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  name                      String?
  role                      Role                       @default(SALJARE)
  emailVerified             DateTime?
  image                     String?
  passwordHash              String?
  totpEnabled               Boolean                    @default(false)
  totpEnabledAt             DateTime?
  /// Encrypted TOTP secret (AES-256-GCM, see src/lib/totp-secrets.ts)
  totpSecret                String?
  /// Encrypted pending TOTP secret when MFA setup is in progress
  totpTempSecret            String?
  accounts                  Account[]
  ordersCreated             Order[]                    @relation("OrderCreatedBy")
  timeEntriesCreated        OrderTrackTimeEntry[]      @relation("TimeEntryCreatedBy")
  timeEntries               OrderTrackTimeEntry[]      @relation("TimeEntryUser")
  outlookCalendarConnection OutlookCalendarConnection?
  sessions                  Session[]
}

model Order {
  orderNumber        String                @id
  title              String
  customerName       String?
  dueDate            DateTime?
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deliveryAddress    String?
  deliveryMethod     String?
  billingConfirmedAt DateTime?
  createdById        String?
  createdByName      String?
  events             CalendarEvent[]
  files              File[]
  fortnox            FortnoxOrderLink?
  createdBy          User?                 @relation("OrderCreatedBy", fields: [createdById], references: [id])
  tracks             OrderTrack[]
  timeEntries        OrderTrackTimeEntry[]
}

model OrderTrack {
  id               String                @id @default(cuid())
  orderId          String
  track            Track
  status           TrackStatus           @default(INKOMMANDE)
  colorHex         String?
  plannedStartAt   DateTime?
  plannedEndAt     DateTime?
  actualStartAt    DateTime?
  actualEndAt      DateTime?
  assignee         String?
  calendarLabel    CalendarLabel?
  timeSpentMinutes Int                   @default(0)
  order            Order                 @relation(fields: [orderId], references: [orderNumber], onDelete: Cascade)
  timeEntries      OrderTrackTimeEntry[]

  @@unique([orderId, track])
  @@index([track, status], map: "ordertrack_track_status_idx")
}

model OrderTrackTimeEntry {
  id             String     @id @default(cuid())
  orderId        String
  track          Track
  minutes        Int
  userId         String?
  userName       String
  userImage      String?
  createdById    String?
  createdByName  String
  createdByImage String?
  createdAt      DateTime   @default(now())
  createdBy      User?      @relation("TimeEntryCreatedBy", fields: [createdById], references: [id])
  order          Order      @relation(fields: [orderId], references: [orderNumber], onDelete: Cascade)
  orderTrack     OrderTrack @relation(fields: [orderId, track], references: [orderId, track], onDelete: Cascade)
  user           User?      @relation("TimeEntryUser", fields: [userId], references: [id])

  @@index([orderId, track, createdAt])
  @@index([userId])
}

model CalendarEvent {
  id      String   @id @default(cuid())
  orderId String
  track   Track
  start   DateTime
  end     DateTime
  title   String
  notes   String?
  order   Order    @relation(fields: [orderId], references: [orderNumber], onDelete: Cascade)
}

model PersonalCalendarEvent {
  id          String               @id @default(cuid())
  track       Track
  title       String
  label       CalendarLabel?
  notes       String?
  allDay      Boolean              @default(false)
  start       DateTime?
  end         DateTime?
  weeklyDays  String?
  startRecur  DateTime?
  endRecur    DateTime?
  startTime   String?
  endTime     String?
  visibility  EventVisibility      @default(PUBLIC)
  ownerUserId String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  outlookSync OutlookCalendarSync?

  @@index([track, visibility, ownerUserId])
}

model OutlookCalendarConnection {
  id                    String                @id @default(cuid())
  userId                String                @unique
  providerUserId        String?
  providerEmail         String?
  displayName           String?
  calendarId            String?               @default("primary")
  accessToken           String
  refreshToken          String
  tokenType             String?
  scope                 String?
  expiresAt             DateTime
  lastSyncedAt          DateTime?
  syncError             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  webhookClientState    String?
  webhookExpiresAt      DateTime?
  webhookSubscriptionId String?
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncedEvents          OutlookCalendarSync[]

  @@index([providerEmail])
}

model OutlookCalendarSync {
  id              String                    @id @default(cuid())
  connectionId    String
  externalEventId String
  externalICalUId String?
  personalEventId String                    @unique
  lastSeenAt      DateTime                  @default(now())
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  connection      OutlookCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  personalEvent   PersonalCalendarEvent     @relation(fields: [personalEventId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalEventId])
  @@index([connectionId, lastSeenAt])
}

model File {
  id              String   @id @default(cuid())
  orderId         String
  track           Track
  filename        String
  url             String
  uploadedBy      String?
  createdAt       DateTime @default(now())
  uploadedById    String?
  uploadedByName  String?
  uploadedByImage String?
  order           Order    @relation(fields: [orderId], references: [orderNumber], onDelete: Cascade)
}

model FortnoxConnection {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  accessToken  String
  refreshToken String
  scope        String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FortnoxOrderLink {
  id             String   @id @default(cuid())
  orderId        String   @unique
  documentNumber String
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [orderNumber], onDelete: Cascade)
}

model CustomerReference {
  id             String   @id @default(cuid())
  customerNumber String
  tenantId       String?
  name           String
  email          String?
  phone          String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, customerNumber])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  SALJARE
  A_TEAM
  B_TEAM
  ADMIN
  C_TEAM
  D_TEAM
}

enum Track {
  A
  B
  SHARED
  C
  D
}

enum TrackStatus {
  INKOMMANDE
  PAGAENDE
  LEVERANS
  AVSLUTAD
  PALACK
}

enum CalendarLabel {
  BOKAD_TID
  KAN_FLYTTAS
  LUNCH
  SEMESTER
  TRAFIKVERKET
  UNDER_VECKAN
  UTFORT_ARBETE
}

enum EventVisibility {
  PUBLIC
  PERSONAL
}

enum DeliveryMethod {
  MONTAGE
  HAMTAS
  UTKORNING
}
